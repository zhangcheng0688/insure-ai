<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<title>Underwriting Memo</title>
<style>
  body { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 11pt; line-height: 1.6; max-width: 700px; margin: 0 auto; padding: 40px; color: #333; }
  h1 { font-size: 20pt; border-bottom: 2px solid #2563eb; padding-bottom: 8px; color: #1e3a5f; }
  h2 { font-size: 14pt; color: #2563eb; margin-top: 24px; }
  table { border-collapse: collapse; width: 100%; margin: 12px 0; }
  th, td { border: 1px solid #ddd; padding: 6px 10px; text-align: left; font-size: 10pt; }
  th { background-color: #f0f4ff; font-weight: bold; }
  .header { text-align: center; margin-bottom: 30px; }
  .confidential { color: red; font-weight: bold; text-align: center; margin-bottom: 20px; }
</style>
</head>
<body>
<div class="header">
  <h1>Underwriting Memorandum</h1>
  <p><strong>Date:</strong> {{ now.strftime('%Y-%m-%d') }}</p>
</div>
<div class="confidential">CONFIDENTIAL — FOR INTERNAL USE ONLY</div>

<h2>Risk Summary</h2>
<table>
  <tr><th>Named Insured</th><td>{{ named_insured }}</td></tr>
  <tr><th>Industry</th><td>{{ industry }}</td></tr>
  <tr><th>Coverage Requested</th><td>{{ coverage }}</td></tr>
  <tr><th>Limits</th><td>{{ limits }}</td></tr>
  <tr><th>Effective Date</th><td>{{ effective_date }}</td></tr>
</table>

<h2>Loss Experience</h2>
{{ loss_analysis }}

<h2>Risk Assessment</h2>
{{ risk_assessment }}

<h2>Recommendation</h2>
{{ recommendation }}

<div style="margin-top: 40px; font-size: 9pt; color: #999; text-align: center;">
  <p>Generated by InsureAI — {{ now.strftime('%Y-%m-%d %H:%M') }}</p>
</div>
</body>
</html>

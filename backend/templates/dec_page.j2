<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Policy Declarations</title>
<style>
  body { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 11pt; line-height: 1.6; max-width: 700px; margin: 0 auto; padding: 40px; color: #333; }
  h1 { font-size: 18pt; text-align: center; border-bottom: 3px double #333; padding-bottom: 10px; }
  .policy-number { text-align: center; font-size: 14pt; font-weight: bold; margin-bottom: 20px; }
  table { border-collapse: collapse; width: 100%; margin: 12px 0; }
  th { background: #333; color: #fff; padding: 8px 10px; text-align: left; font-size: 10pt; }
  td { border: 1px solid #ccc; padding: 6px 10px; font-size: 10pt; }
  .total-row { font-weight: bold; background: #f5f5f5; }
</style>
</head>
<body>
<h1>POLICY DECLARATIONS</h1>
<p class="policy-number">Policy Number: {{ policy_number }}</p>

<table>
  <tr><td style="width:30%"><strong>Named Insured:</strong></td><td>{{ named_insured }}</td></tr>
  <tr><td><strong>Mailing Address:</strong></td><td>{{ insured_address }}</td></tr>
  <tr><td><strong>Policy Period:</strong></td><td>{{ policy_period }}</td></tr>
  <tr><td><strong>Business Description:</strong></td><td>{{ business_description }}</td></tr>
</table>

<h2>Coverages &amp; Premiums</h2>
<table>
  <tr><th>Coverage</th><th>Limit of Liability</th><th>Deductible</th><th>Annual Premium</th></tr>
  {{ coverage_rows }}
  <tr class="total-row"><td colspan="3"><strong>TOTAL ANNUAL PREMIUM</strong></td><td><strong>{{ total_premium }}</strong></td></tr>
</table>

<h2>Forms &amp; Endorsements</h2>
{{ forms_endorsements }}

<div style="margin-top: 30px; font-size: 9pt; color: #999; text-align: center;">
  <p>Generated by InsureAI — {{ now.strftime('%Y-%m-%d %H:%M') }}</p>
</div>
</body>
</html>

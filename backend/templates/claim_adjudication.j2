<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<title>Claim Adjudication Memo</title>
<style>
  body { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 11pt; line-height: 1.6; max-width: 700px; margin: 0 auto; padding: 40px; color: #333; }
  h1 { font-size: 20pt; border-bottom: 2px solid #dc2626; padding-bottom: 8px; color: #7f1d1d; }
  h2 { font-size: 14pt; color: #dc2626; margin-top: 24px; }
  table { border-collapse: collapse; width: 100%; margin: 12px 0; }
  th, td { border: 1px solid #ddd; padding: 6px 10px; text-align: left; font-size: 10pt; }
  th { background-color: #fef2f2; font-weight: bold; }
  .coverage-covered { color: #16a34a; font-weight: bold; }
  .coverage-partial { color: #ea580c; font-weight: bold; }
  .coverage-excluded { color: #dc2626; font-weight: bold; }
</style>
</head>
<body>
<div style="text-align: center; margin-bottom: 30px;">
  <h1>Claim Adjudication Memorandum</h1>
  <p><strong>Claim Number:</strong> {{ claim_number }} | <strong>Date:</strong> {{ now.strftime('%Y-%m-%d') }}</p>
</div>

<h2>Claim Summary</h2>
<table>
  <tr><th>Date of Loss</th><td>{{ date_of_loss }}</td></tr>
  <tr><th>Cause of Loss</th><td>{{ cause_of_loss }}</td></tr>
  <tr><th>Insured</th><td>{{ insured }}</td></tr>
  <tr><th>Claimant</th><td>{{ claimant }}</td></tr>
</table>

<h2>Coverage Analysis</h2>
{{ coverage_analysis }}

<h2>Reserve Recommendation</h2>
{{ reserve_recommendation }}

<h2>Adjudication Decision</h2>
{{ adjudication_decision }}

<div style="margin-top: 40px; font-size: 9pt; color: #999; text-align: center;">
  <p>Generated by InsureAI — {{ now.strftime('%Y-%m-%d %H:%M') }}</p>
</div>
</body>
</html>

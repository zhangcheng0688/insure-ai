<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<title>Renewal Proposal</title>
<style>
  body { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 11pt; line-height: 1.6; max-width: 700px; margin: 0 auto; padding: 40px; color: #333; }
  h1 { font-size: 20pt; border-bottom: 2px solid #16a34a; padding-bottom: 8px; color: #14532d; }
  h2 { font-size: 14pt; color: #16a34a; margin-top: 24px; }
  table { border-collapse: collapse; width: 100%; margin: 12px 0; }
  th, td { border: 1px solid #ddd; padding: 6px 10px; text-align: left; font-size: 10pt; }
  th { background-color: #f0fdf4; font-weight: bold; }
  .premium-up { color: #dc2626; }
  .premium-down { color: #16a34a; }
</style>
</head>
<body>
<div style="text-align: center; margin-bottom: 30px;">
  <h1>Insurance Renewal Proposal</h1>
  <p><strong>Insured:</strong> {{ insured }} | <strong>Date:</strong> {{ now.strftime('%Y-%m-%d') }}</p>
</div>

<h2>Renewal Terms</h2>
{{ renewal_terms }}

<h2>Loss Experience</h2>
{{ loss_experience }}

<h2>Premium Analysis</h2>
{{ premium_analysis }}

<h2>Recommendations</h2>
{{ recommendations }}

<div style="margin-top: 40px; font-size: 9pt; color: #999; text-align: center;">
  <p>Generated by InsureAI — {{ now.strftime('%Y-%m-%d %H:%M') }}</p>
</div>
</body>
</html>
